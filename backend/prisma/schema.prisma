generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider  = "postgresql"
}

// ── USUARIOS ──
model Usuario {
  id       String   @id @default(uuid())
  email    String   @unique
  password String
  rol      Rol      @default(CANDIDATO)
  creadoEn DateTime @default(now())

  candidato Candidato?
  empresa   Empresa?
  notificaciones Notificacion[]
}

enum Rol {
  CANDIDATO
  EMPRESA
}

// ── CANDIDATO ──
model Candidato {
  id                   String   @id @default(uuid())
  nombre               String
  apellido             String
  ubicacion            String?
  telefono             String?
  linkedin             String?
  cvUrl                String?
  scoreCV              Int?
  resumenIA            String?
  habilidades          String[] // array plano usado por el match IA low-token
  habilidadesFaltantes String[] // sugerencias de la IA
  formacion            String[] // títulos y estudios detectados por la IA
  creadoEn             DateTime @default(now())

  usuarioId String  @unique
  usuario   Usuario @relation(fields: [usuarioId], references: [id])

  postulaciones   Postulacion[]
  habilidadesTech HabilidadCandidato[]
  experiencias    ExperienciaCandidato[]
  matchAnalisis   MatchAnalisis[]
}

// ── HABILIDADES DEL CANDIDATO (extraídas por IA) ──
model HabilidadCandidato {
  id          String        @id @default(uuid())
  nombre      String
  tipo        TipoHabilidad
  candidatoId String
  candidato   Candidato     @relation(fields: [candidatoId], references: [id], onDelete: Cascade)
}

enum TipoHabilidad {
  TECNICA
  BLANDA
  TECNOLOGIA
}

// ── EXPERIENCIA LABORAL DEL CANDIDATO (extraída por IA) ──
model ExperienciaCandidato {
  id          String    @id @default(uuid())
  rol         String
  empresa     String
  desde       String
  hasta       String
  descripcion String?
  candidatoId String
  candidato   Candidato @relation(fields: [candidatoId], references: [id], onDelete: Cascade)
}

// ── EMPRESA ──
model Empresa {
  id            String   @id @default(uuid())
  nombre        String
  industria     String?
  descripcion   String?
  ubicacion     String?
  sitioWeb      String?
  anoFundacion  Int?
  tamanoEmpresa String?
  creadoEn      DateTime @default(now())

  usuarioId String  @unique
  usuario   Usuario @relation(fields: [usuarioId], references: [id])

  ofertas OfertaLaboral[]
}

// ── OFERTA LABORAL ──
model OfertaLaboral {
  id                String    @id @default(uuid())
  titulo            String
  descripcion       String
  rubro             String
  modalidad         String
  ubicacion         String
  jornada           String
  vacantes          Int?      @default(1)
  fechaLimite       DateTime?
  experiencia       String?
  estudios          String?
  salarioMin        Int?
  salarioMax        Int?
  habilidades       String[]
  responsabilidades String[]
  beneficios        String[]
  esBorrador        Boolean   @default(false)
  creadoEn          DateTime  @default(now())

  empresaId String
  empresa   Empresa @relation(fields: [empresaId], references: [id])

  postulaciones Postulacion[]
  matchAnalisis MatchAnalisis[]
}

// ── POSTULACION ──
model Postulacion {
  id                    String    @id @default(uuid())
  estado                Estado    @default(PENDIENTE)
  cartaMotivacion       String?
  matchIA               Int?
  matchAnalizadoEmpresa Boolean   @default(false)
  matchAnalizadoEn      DateTime?
  creadoEn              DateTime  @default(now())
  notes                 String?

  candidatoId String
  candidato   Candidato @relation(fields: [candidatoId], references: [id])

  ofertaId String
  oferta   OfertaLaboral @relation(fields: [ofertaId], references: [id])

  entrevistas Entrevista[]

  @@unique([candidatoId, ofertaId])
}

model MatchAnalisis {
  id          String   @id @default(uuid())
  candidatoId String
  ofertaId    String
  match       Int
  creadoEn    DateTime @default(now())

  candidato Candidato     @relation(fields: [candidatoId], references: [id], onDelete: Cascade)
  oferta    OfertaLaboral @relation(fields: [ofertaId], references: [id], onDelete: Cascade)

  @@unique([candidatoId, ofertaId])
}

// ── ENTREVISTA ──
model Entrevista {
  id          String   @id @default(uuid())
  fecha       DateTime
  linkReunion String?
  creadaEn    DateTime @default(now())

  postulacionId String
  postulacion   Postulacion @relation(fields: [postulacionId], references: [id])
}

enum Estado {
  PENDIENTE
  REVISADA
  ENTREVISTA
  RECHAZADA
}

// ── NOTIFICACIONES ──
model Notificacion {
  id       String   @id @default(uuid())
  titulo   String
  mensaje  String
  tipo     String   @default("info") // info, success, warning, alert
  leida    Boolean  @default(false)
  link     String?
  creadoEn DateTime @default(now())

  usuario   Usuario @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  usuarioId String
}
